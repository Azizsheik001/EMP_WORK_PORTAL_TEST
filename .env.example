# Frontend (Vite)
# Copy to .env and fill in. Never commit .env or real keys.

# Supabase (optional — for direct Supabase client)
# VITE_SUPABASE_URL=https://your-project-ref.supabase.co
# VITE_SUPABASE_ANON_KEY=your-anon-key-jwt

# Supabase Storage (backend) — required for idea attachments.
# Set these in backend/.env, not here:
#   SUPABASE_SERVICE_ROLE_KEY=<service-role-jwt-from-supabase-dashboard>
#   SUPABASE_URL=https://<project-ref>.supabase.co   (optional — auto-derived from DATABASE_URL)
#   SUPABASE_BUCKET=idea-attachments                 (optional — defaults to this name)

# Backend API — set this to use the Node API (auth, leave, shifts, schedules)
VITE_API_URL=http://localhost:3000

# AGS Suite API — for SSO auto-login from the AGS Suite dashboard
# Falls back to http://localhost:3001 (dev) or https://ags-suite-api.vercel.app (prod)
# VITE_SUITE_API_URL=http://localhost:3001
